{
    "name": "YaSolR",
    "build": {
        "context": ".",
        "dockerfile": "Dockerfile"
    },
    "postStartCommand": {
        "git and submodules setup": "git config -l | grep -q \"x-access-token:${GITHUB_TOKEN}\" && echo 'Git is already configured ..' || (git config --replace-all --global url.https://x-access-token:${GITHUB_TOKEN}@github.com/.insteadOf ssh://git@github.com/ && git config --add --global url.https://x-access-token:${GITHUB_TOKEN}@github.com/.insteadOf git@github.com/ && git config --add --global url.https://x-access-token:${GITHUB_TOKEN}@github.com/.insteadOf git@github.com: && git submodule update --init --recursive)"
    },
    "customizations": {
        "codespaces": {
            "repositories": {
                "mathieucarbou/WebSerial-Pro": {
                    "permissions": {
                        "contents": "read"
                    }
                },
                "mathieucarbou/ESP-DASH-Pro": {
                    "permissions": {
                        "contents": "read"
                    }
                }
            }
        },
        "vscode": {
            "settings": {
                "git.enableCommitSigning": false
            },
            "extensions": [
                "alexnesnes.teleplot",
                "DavidAnson.vscode-markdownlint",
                "dbaeumer.vscode-eslint",
                "docker.docker",
                "donjayamanne.githistory",
                "eamodio.gitlens",
                "esbenp.prettier-vscode",
                "GitHub.codespaces",
                "GitHub.copilot-chat",
                "github.github-vscode-theme",
                "github.remotehub",
                "github.vscode-github-actions",
                "github.vscode-pull-request-github",
                "gitpod.gitpod-flex-remote",
                "gitpod.gitpod-theme",
                "grapecity.gc-excelviewer",
                "Gruntfuggly.todo-tree",
                "Jason2866.esp-decoder",
                "mechatroner.rainbow-csv",
                "mhutchie.git-graph",
                "ms-azuretools.vscode-containers",
                "ms-azuretools.vscode-docker",
                "ms-edgedevtools.vscode-edge-devtools",
                "ms-python.autopep8",
                "ms-python.black-formatter",
                "ms-python.debugpy",
                "ms-python.pylint",
                "ms-python.python",
                "ms-python.vscode-pylance",
                "ms-python.vscode-python-envs",
                "ms-vscode-remote.remote-containers",
                "ms-vscode-remote.remote-ssh-edit",
                "ms-vscode-remote.remote-ssh",
                "ms-vscode.cmake-tools",
                "ms-vscode.cpp-devtools",
                "ms-vscode.cpptools-extension-pack",
                "ms-vscode.cpptools-themes",
                "ms-vscode.cpptools",
                "ms-vscode.hexeditor",
                "ms-vscode.makefile-tools",
                "ms-vscode.remote-explorer",
                "ms-vscode.remote-repositories",
                "ms-vscode.test-adapter-converter",
                "ms-vscode.vscode-serial-monitor",
                "ms-vscode.vscode-websearchforcopilot",
                "paragdiwan.gitpatch",
                "pioarduino.pioarduino-ide",
                "rapidapi.vscode-services",
                "redhat.vscode-xml",
                "redhat.vscode-yaml",
                "rvest.vs-code-prettier-eslint",
                "slevesque.vscode-zipexplorer",
                "svelte.svelte-vscode",
                "timheuer.awesome-copilot",
                "tomoki1207.pdf",
                "yzane.markdown-pdf",
                "ziyasal.vscode-open-in-github"
            ]
        }
    }
}